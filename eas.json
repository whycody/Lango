{
    "cli": {
        "version": ">= 15.0.6",
        "appVersionSource": "remote",
        "promptToConfigurePushNotifications": false
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "channel": "development"
        },
        "preview": {
            "android": {
                "buildType": "apk"
            },
            "channel": "preview",
            "environment": "preview"
        },
        "test": {
            "android": {
                "buildType": "apk"
            },
            "channel": "test",
            "environment": "development"
        },
        "production": {
            "channel": "production",
            "android": {
                "buildType": "app-bundle",
                "gradleCommand": ":app:bundleRelease -x lint -x lintVitalAnalyzeRelease"
            },
            "env": {
                "ORG_GRADLE_PROJECT_org.gradle.jvmargs": "-Xmx6144m -XX:MaxMetaspaceSize=2048m -Dfile.encoding=UTF-8",
                "ORG_GRADLE_PROJECT_org.gradle.workers.max": "2"
            },
            "environment": "production",
            "autoIncrement": true
        }
    },
    "submit": {
        "production": {}
    }
}
